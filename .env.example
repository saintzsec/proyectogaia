# =========================================================
# GAIA - Environment template
# Copy this file to .env.local and fill in your values.
# =========================================================

# Supabase project URL (Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key (Settings -> API -> anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL
# Local:  http://localhost:3000
# Vercel: https://your-app.vercel.app
# Custom: https://proyectogaia.org
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase service role key (server-only, never expose in NEXT_PUBLIC_*)
# Required by server actions that perform privileged writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
